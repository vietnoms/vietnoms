# Database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Auth
AUTH_SECRET=hex-encoded-32-byte-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password

# White-label branding (all optional, defaults provided)
NEXT_PUBLIC_BRAND_NAME=VenueForecast
NEXT_PUBLIC_BRAND_TAGLINE=Event impact forecasting for local businesses
NEXT_PUBLIC_LOGO_URL=
NEXT_PUBLIC_COLOR_PRIMARY=#3b82f6
NEXT_PUBLIC_COLOR_PRIMARY_HOVER=#2563eb

# Email integration (for external ingest services)
INGEST_API_KEY=random-secret-for-ingest-service
